# ─── NJ Transit API credentials ───────────────────────────────────────────────
# Register for free at https://datasource.njtransit.com
# Once approved, use the username and password from your developer account.

NJT_USERNAME=your_njt_username_here
NJT_PASSWORD=your_njt_password_here

# ─── Mock mode ─────────────────────────────────────────────────────────────────
# Set to "true" to use realistic mock data instead of calling the real NJT API.
# Use this for local development before you have credentials, or for testing.
# Remove this variable (or set to "false") to use the live NJT API.

USE_MOCK_API=true
